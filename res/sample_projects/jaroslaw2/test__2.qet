                    <description>
                        <rect width="44" x="0" height="120" y="70.0" antialias="false" style="line-style:normal;line-weight:normal;filling:none;color:black"/>
                        <dynamic_text text_from="UserText" rotation="270" font_size="13" z="3" frame="false" x="9.0" uuid="{63d0dcd0-b14a-11eb-8368-6b05cb93ba68}" y="175.5">
